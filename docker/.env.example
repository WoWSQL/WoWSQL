# ─── WoWSQL Self-Hosted Configuration ────────────────────────────────────────
# Copy this file to .env and change the values below.

# ─── REQUIRED: Change these! ─────────────────────────────────────────────────

# PostgreSQL superuser password
POSTGRES_PASSWORD=your-super-secret-password-change-me

# JWT secret (min 32 characters) — used by PostgREST, Auth, Backend
# API keys (anon + service_role) are auto-generated from this secret!
JWT_SECRET=your-jwt-secret-at-least-32-characters-long!!

# ─── OPTIONAL: Defaults work for local development ──────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# PostgREST authenticator role password (must match 01-init-roles.sql)
AUTHENTICATOR_PASSWORD=wowsql_auth_pass

# Redis
REDIS_PORT=6379

# Kong API Gateway
API_PORT=8080
API_PORT_SSL=8443

# Studio Dashboard
STUDIO_PORT=3000

# External URLs (change if running behind a reverse proxy)
API_EXTERNAL_URL=http://localhost:8080
WS_EXTERNAL_URL=ws://localhost:8080
STUDIO_EXTERNAL_URL=http://localhost:3000
